# ── 必填 ──────────────────────────────────────────────
# 设备唯一标识（建议用小写连字符，如 work-pc、home-pc）
DEVICE_ID=work-pc
# 设备显示名称
DEVICE_NAME=Work PC
# 服务端地址
SERVER_URL=http://your-vps-ip:3000
# 与服务端 .env 里的 API_KEY 保持一致
API_KEY=change-me-to-a-random-secret

# ── 心跳间隔（秒，默认 10）─────────────────────────────
# HEARTBEAT_INTERVAL=10

# ── AI 扩展点（可选，启用后每次心跳截图并生成描述）────────
# 设置后自动启用截图 + AI 描述功能
# ANTHROPIC_API_KEY=sk-ant-...
# AI 模型（默认 claude-haiku-4-5-20251001，最快最便宜）
# AI_MODEL=claude-haiku-4-5-20251001
# 截图频率：每 N 次心跳截一次图（默认 6，即每分钟一次）
# AI_SCREENSHOT_EVERY=6
