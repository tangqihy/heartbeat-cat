# ── 必填 ──────────────────────────────────────────────────────────
DEVICE_ID=steam-deck
DEVICE_NAME=Steam Deck
SERVER_URL=http://your-vps-ip:3000
API_KEY=change-me-to-a-random-secret

# ── 可选 ──────────────────────────────────────────────────────────
# 心跳间隔（秒，默认 10）
# HEARTBEAT_INTERVAL=10

# Steam 库路径（默认 ~/.local/share/Steam/steamapps）
# 如果游戏装在其他磁盘，逗号分隔添加多个路径
# STEAM_LIBRARY_PATHS=/home/deck/.local/share/Steam/steamapps,/run/media/mmcblk0p1/steamapps

# ── AI 扩展点（可选）──────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-haiku-4-5-20251001
# AI_SCREENSHOT_EVERY=6

# ── 前置依赖 ──────────────────────────────────────────────────────
# Desktop Mode 需要 xdotool:   sudo pacman -S xdotool
# Gaming Mode  无需额外依赖（读 /proc）
# Input counting 需要 libxtst: sudo pacman -S libxtst
